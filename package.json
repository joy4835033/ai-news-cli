{
  "name": "ai-news-cli",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "daily":    "tsx src/index.ts",
    "build":    "tsx src/build.ts",
    "cron":     "tsx src/index.ts --cron",
    "cron:now": "tsx src/index.ts --cron --now",
    "verbose":  "tsx src/index.ts --verbose",
    "serve":    "tsx src/server.ts",
    "start":    "tsx src/index.ts && tsx src/server.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "fast-xml-parser": "^4.3.6",
    "marked": "^12.0.0",
    "node-cron": "^3.0.3",
    "openai": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
